# Central_Server Environment Variables
# Copy this file to .env and fill in the values

# HD Wallet — BIP-39 mnemonic (24 words), NEVER commit to git or expose via API/log
MASTER_SEED_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24

# Supabase (Central/Pusat)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=<REDACTED_SUPABASE_KEY>

# Moralis API (untuk monitor deposit BSC USDT)
# Daftar gratis di https://moralis.io → Web3 APIs → copy API key
MORALIS_API_KEY=your-moralis-api-key-here

# Bot Pusat Telegram Token (untuk notifikasi ke WL Owner)
BOT_TOKEN=your-telegram-bot-token-here

# License API Port
LICENSE_API_PORT=8080
