[deployment]
run = ["sh", "-c", "cd Bismillah && python3 main.py"]
deploymentTarget = "gce"
ignorePorts = true

[workflows]
runButton = "Run Bot"

[[workflows.workflow]]
name = "Run Bot"
author = 43938181
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Bismillah && python3 main.py"
