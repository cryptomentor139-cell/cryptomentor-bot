
entrypoint = "Bismillah/main.py"
modules = ["python-3.11", "postgresql-16"]

[nix]
channel = "stable-25_05"

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["sh", "-c", "cd Bismillah && python main.py"]
deploymentTarget = "gce"
ignorePorts = true

[env]
PYTHONPATH = "./Bismillah:."
PYTHONUNBUFFERED = "1"
PYTHONDONTWRITEBYTECODE = "1"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start Bot"
author = 43938181
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Bismillah && python main.py"
run = "python3 main.py"
language = "python3"

[[workflows.workflow]]
name = "Start Bot Clean"
author = 43938181
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f \"python.*main.py\" || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 2"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Bismillah && python main.py"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "bot-server"

[[workflows.workflow]]
name = "bot-server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd ./Bismillah && python main.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start Bot with Menu"
author = 43938181
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Bismillah && python main.py"

[agent]
expertMode = true
