# ============================================
# WHITELABEL #1 — ENVIRONMENT VARIABLES
# Semua API key di sini TERPISAH dari CryptoMentor utama
# ============================================

# ── Telegram ──────────────────────────────────────────
BOT_TOKEN=<REDACTED_TELEGRAM_BOT_TOKEN>
ADMIN1=<REDACTED_ADMIN_ID>
ADMIN2=
ADMIN3=

# ── Supabase (instance TERPISAH untuk WL#1) ───────────
SUPABASE_URL=https://jajtwunmngmturqwjpum.supabase.co
SUPABASE_ANON_KEY=<REDACTED_SUPABASE_KEY>
SUPABASE_SERVICE_KEY=<REDACTED_SUPABASE_KEY>

# ── AI Provider (key TERPISAH) ────────────────────────
# OpenRouter (untuk Gemini/DeepSeek/Claude)
DEEPSEEK_API_KEY=your_openrouter_api_key_wl1
DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=google/gemini-flash-1.5

# ── Crypto Data Providers (key TERPISAH) ─────────────
# PENTING: Gunakan API key berbeda dari CryptoMentor utama
# agar tidak share rate limit

# CryptoCompare — https://min-api.cryptocompare.com (free tier tersedia)
CRYPTOCOMPARE_API_KEY=your_cryptocompare_api_key_wl1

# Helius RPC (Solana) — https://www.helius.dev (free tier tersedia)
HELIUS_API_KEY=your_helius_api_key_wl1

# CoinGecko — https://www.coingecko.com/en/api (free tier atau Pro)
# Free tier tidak butuh key, tapi Pro key menghindari rate limit
COINGECKO_API_KEY=your_coingecko_pro_key_wl1

# CryptoNews — https://cryptonews-api.com (opsional)
CRYPTONEWS_API_KEY=your_cryptonews_api_key_wl1

# ── Bitunix (autotrade) ───────────────────────────────
BITUNIX_BASE_URL=https://fapi.bitunix.com
BITUNIX_WS_URL=wss://fapi.bitunix.com/private
BITUNIX_REFERRAL_CODE=kode_referral_owner_wl1
BITUNIX_REFERRAL_URL=https://www.bitunix.com/register?vipCode=kode_referral_owner_wl1

# ── License (dari CryptoMentor Central Server) ────────
WL_ID=your-wl-uuid-here
WL_SECRET_KEY=<REDACTED_WL_SECRET_KEY>
LICENSE_API_URL=https://license.cryptomentor.ai

# ── Bot Settings ──────────────────────────────────────
WELCOME_CREDITS=100
BOT_NAME=CryptoMentor AI
BOT_TAGLINE=Your AI Crypto Trading Assistant
USE_LEGACY_FUTURES_SIGNALS=true
