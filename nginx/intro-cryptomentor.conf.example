# Step 1 (safe/default): HTTP-only config so intro subdomain works immediately.
# Deploy the static onboarding file to an nginx-readable path (recommended):
#   /var/www/intro-cryptomentor/cryptomentor-onboarding-deck.html
server {
    listen 80;
    server_name intro.cryptomentor.id;

    root /var/www/intro-cryptomentor;
    index index.html;

    location = / {
        return 302 /cryptomentor-onboarding-deck.html;
    }

    location / {
        try_files $uri $uri/ =404;
    }
}

